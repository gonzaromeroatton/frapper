# .gitignore para proyecto .NET (Frapper)
# Ignora carpetas y archivos generados que no deben subirse al repositorio

# Builds
**/bin/
**/obj/

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# VS Code (descomenta si quieres versionar settings compartidos)
.vscode/

# Rider
.idea/
*.Rider*

# NuGet
*.nupkg
packages/
project.assets.json
.nuget/

# Publicaciones / despliegues
publish/
**/publish/

# Resultados de pruebas / logs
TestResults/
*.trx
*.log

# Archivos generados por la compilación / runtime
*.dll
*.exe
*.pdb
*.runtimeconfig.json
*.deps.json

# System files
Thumbs.db
.DS_Store

# Otros temporales
*.tmp
*.temp

# Nota: si deseas incluir la carpeta .vscode con settings compartidos, elimina la línea ".vscode/" de este archivo.
